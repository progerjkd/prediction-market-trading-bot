# Trading mode
LIVE_TRADING=false
BANKROLL_USDC=10000

# Budgets
DAILY_API_COST_LIMIT=50
DAILY_LOSS_LIMIT_PCT=0.15
MAX_DRAWDOWN_PCT=0.08
MAX_OPEN_POSITIONS=15
MAX_POSITION_PCT=0.05
