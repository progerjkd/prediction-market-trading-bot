# Polymarket credentials (L1 - private key derives L2 API creds)
PK=
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=

# Anthropic
ANTHROPIC_API_KEY=

# Reddit (optional - leave blank to skip Reddit research)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
